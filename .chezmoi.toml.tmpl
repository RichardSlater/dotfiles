{{ if eq .chezmoi.os "windows" }}
[cd]
    command = "pwsh.exe"
    args = ["-NoLogo"]
[interpreters.ps1]
    command = "pwsh.exe"
    args = ["-NoLogo"]
[diff]
    command = "C:\\Program Files\\Neovim\\bin\\nvim.exe"
    args = ["-d"]
{{ end }}

[data]
    email = "{{- if eq .chezmoi.username "scetrov" -}}git@scetrov.live{{- else -}}github@richard-slater.co.uk{{- end -}}"
    role = personal
